# EditorConfig — https://editorconfig.org
# Honored natively by PyCharm (and most editors). Reinforces the repo's LF
# policy (.gitattributes) and mirrors the ruff config in pyproject.toml, so the
# IDE and the linter/formatter agree.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
max_line_length = 88

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.md]
# Trailing whitespace is significant in Markdown (two spaces = hard line break).
trim_trailing_whitespace = false
